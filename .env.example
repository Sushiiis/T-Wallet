APP_ENV=local

GRPC_PORT=50051
HTTP_PORT=8080
SHUTDOWN_TIMEOUT=10s

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=twallet
POSTGRES_PASSWORD=twallet_pass
POSTGRES_DB=twallet
POSTGRES_SSLMODE=disable

JWT_SECRET=super_secret_change_me
