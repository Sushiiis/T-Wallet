KAFKA_CONSUMER_GROUP=notifier
KAFKA_RELAY_INTERVAL=500ms

OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_SERVICE_NAME=t-wallet
TRACING_ENABLED=true